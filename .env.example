# Copy this file to .env.local and fill in the values you need.
# .env.local is gitignored. This file is not.

# Required. Anthropic API key.
# Used for bill classification, blurb generation, news summarization,
# officials research, and the regional overview prose on the home page.
ANTHROPIC_API_KEY=

# Required. Tavily API key.
# Used for provincial legislation research, housing projects discovery,
# officials biographical enrichment, and sourceUrl validation.
# Free dev tier is 1000 credits per month. See https://tavily.com
TAVILY_API_KEY=

# Optional. FRED (Federal Reserve Economic Data) API key.
# Used by scripts/sync/fred-housing.ts for US housing metrics
# (Case-Shiller, mortgage rate, housing starts, vacancy). Free.
# See https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ----------------------------------------------------------------
# Optional. US data source enhancements
# ----------------------------------------------------------------

# Congress.gov API key. Primary source for US federal bills.
# Register free at https://api.congress.gov/sign-up/
# Rate limit: 5000 requests/hour. No key means the federal pipeline
# fails fast rather than falling through to Tavily.
CONGRESS_GOV_API_KEY=

# Apify API token. Enables state-legislature scrapers for states
# without LegiScan or useful Tavily results (Colorado, Arizona today).
# Get one at https://console.apify.com/settings/integrations
# Free tier: $5 compute credit per month, tracked in
# data/raw/apify/_usage.json with a soft/hard cap in the client.
APIFY_API_TOKEN=

# LegiScan API key. Canonical source for US state bills. Dormant until
# this is populated; apply at https://legiscan.com/legiscan.
# Rate limit: 30000 requests/month on the free tier. When set, the
# us-legiscan-housing pipeline upgrades sourceUrl + stage on every
# merged bill on the next weekly sync.
LEGISCAN_API_KEY=

# Optional. Vercel KV for the live visitor counter on the home page.
# Omit both variables to fall back to the cosmetic client-side count.
KV_REST_API_URL=
KV_REST_API_TOKEN=
