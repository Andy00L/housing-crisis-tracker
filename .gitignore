# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# keep the template checked in so contributors know which keys to set
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sync pipeline caches — regenerable, not committed
/data/raw
!data/raw/_health.json
/data/sources

# claude code local state
/.claude
/skills-lock.json
/legiscan-survey.txt

# Planning and reference docs (local only)
phases.md
upgrade.md
REFERENCE_SECURITY_AUDIT.md
