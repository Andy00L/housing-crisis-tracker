# Normalize all text files to LF line endings
* text=auto eol=lf

# Force LF for shell scripts, YAML, JSON
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.md       text eol=lf

# Binary files, do not touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.woff     binary
*.woff2    binary
